{
  "name": "aramis",
  "version": "0.4.2",
  "private": true,
  "description": "AI-powered web terminal agent for sysadmin/devops — chat instead of CLI",
  "author": {
    "name": "Aliasghar Ramin",
    "url": "https://aramin.co"
  },
  "homepage": "https://aramin.co",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "install:all": "npm install && npm --prefix web install",
    "dev": "concurrently -n server,web -c blue,magenta \"npm --prefix server run dev\" \"npm --prefix web run dev\"",
    "build:web": "npm --prefix web run build",
    "build": "npm run build:web",
    "start": "npm --prefix server start",
    "electron:dev": "npm run build:web && electron .",
    "electron:rebuild": "electron-builder install-app-deps",
    "electron:build:mac": "npm run build:web && electron-builder --mac --publish=never",
    "electron:build:win": "npm run build:web && electron-builder --win --publish=never",
    "electron:build:linux": "npm run build:web && electron-builder --linux --publish=never",
    "electron:build:all": "npm run build:web && electron-builder -mwl --publish=never",
    "icon:generate": "node electron/generate-icon.mjs",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry-run",
    "postinstall": "electron-builder install-app-deps || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "basic-ftp": "^6.0.1",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.9",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "sharp": "^0.33.5"
  },
  "build": {
    "appId": "co.aramin.aramis",
    "productName": "Aramis",
    "copyright": "Copyright © 2026 Aliasghar Ramin (aramin.co)",
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/bcrypt/**/*"
    ],
    "files": [
      "electron/**/*",
      "server/src/**/*",
      "server/package.json",
      "web/dist/**/*",
      "package.json",
      "!**/.DS_Store",
      "!**/*.md",
      "CHANGELOG.md",
      "!server/data/**/*",
      "!**/.env*",
      "!**/{__tests__,test,tests,powered-test,example,examples}",
      "!**/{.eslintrc.json,.eslintrc.js,.prettierrc,.editorconfig,tsconfig.json}"
    ],
    "directories": {
      "output": "dist-electron",
      "buildResources": "electron"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "Aramis ${version} ${arch}",
      "iconSize": 96,
      "window": {
        "width": 540,
        "height": 360
      },
      "contents": [
        {
          "x": 140,
          "y": 180,
          "type": "file"
        },
        {
          "x": 400,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Aramis"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "electron/icon.png",
      "category": "Development"
    }
  }
}
